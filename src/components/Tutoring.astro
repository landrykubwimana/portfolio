---
import { profile } from '../data/profile';

const { tutoring } = profile;
---

<section class="section" id="tutorat">
  <div class="wrap">
    <div class="tutoring">
      <div>
        <span class="eyebrow">Services de tutorat</span>
        <h2 class="tutoring-title">{tutoring.headline}</h2>
        <p class="tutoring-desc">{tutoring.description}</p>
        <div class="subjects">
          {tutoring.subjects.map((s) => <span class="subject-chip">{s}</span>)}
        </div>
      </div>

      <div class="tutoring-cta">
        <a class="btn btn-accent" href={tutoring.url} target="_blank" rel="noopener">
          Accéder au service de tutorat <span class="arrow">→</span>
        </a>
        <span class="tutoring-note">
          Prise de rendez-vous, suivi des devoirs et examens sur le site dédié.
        </span>
      </div>
    </div>
  </div>
</section>
