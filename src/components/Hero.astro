---
import { profile } from '../data/profile';

const firstName = profile.name.split(' ')[0];
---

<section class="wrap hero" id="top">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>

  <div class="hero-text">
    {
      profile.available && (
        <span class="pill reveal d1">
          <span class="dot" />
          {profile.availableLabel}
        </span>
      )
    }

    <h1 class="hero-title reveal d2">
      Bonjour, moi c'est<br /><span class="accent">{firstName}.</span>
    </h1>

    <p class="role reveal d3">{profile.role}</p>
    <p class="lead reveal d3">{profile.tagline}</p>

    <div class="cta-row reveal d4">
      <a class="btn btn-primary" href="#projets">
        Voir mes projets <span class="arrow">→</span>
      </a>
      <a class="btn btn-ghost" href="#tutorat">Réserver du tutorat</a>
    </div>

    <div class="chips reveal d5">
      <span class="chip">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z" /><path d="M6 12v5c3 3 9 3 12 0v-5" /></svg>
        Parcours académique
      </span>
      <span class="chip">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" /><path d="M8 21h8M12 17v4" /></svg>
        Projets &amp; réalisations
      </span>
      <span class="chip">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" /></svg>
        Tutorat
      </span>
    </div>
  </div>

  <div class="visual reveal d4">
    <div class="portrait">
      {
        profile.photo ? (
          <img
            class="portrait-img"
            src={profile.photo}
            alt={`Portrait de ${profile.name}`}
            loading="eager"
          />
        ) : (
          <span class="initials">{profile.initials}</span>
        )
      }
    </div>

    <div class="badge badge-1">
      <span class="ic">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" /></svg>
      </span>
      <div>
        <strong>Projets</strong>
        <small>Portfolio à jour</small>
      </div>
    </div>

    <div class="badge badge-2">
      <span class="ic">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><path d="m22 4-10 10.01-3-3" /></svg>
      </span>
      <div>
        <strong>Tutorat</strong>
        <small>Réserve une séance</small>
      </div>
    </div>
  </div>
</section>
