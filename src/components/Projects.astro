---
import { profile } from '../data/profile';
---

<section class="section" id="projets">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Réalisations</span>
      <h2 class="section-title">Projets</h2>
      <p class="section-intro">
        Une sélection de projets en science des données, analytique et recherche.
      </p>
    </div>

    <div class="proj-grid">
      {
        profile.projects.map((p) => (
          <article class="proj-card">
            <h3 class="proj-title">{p.title}</h3>
            <p class="proj-desc">{p.description}</p>

            {p.tags.length > 0 && (
              <div class="proj-tags">
                {p.tags.map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
            )}

            {(p.repo || p.demo) && (
              <div class="proj-links">
                {p.repo && (
                  <a class="proj-link" href={p.repo} target="_blank" rel="noopener">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.72-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.3-.52-1.47.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.23 2.75.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.4-5.25 5.69.41.36.78 1.05.78 2.12v3.14c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z" /></svg>
                    Code
                  </a>
                )}
                {p.demo && (
                  <a class="proj-link" href={p.demo} target="_blank" rel="noopener">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><path d="M15 3h6v6M10 14 21 3" /></svg>
                    Démo
                  </a>
                )}
              </div>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
